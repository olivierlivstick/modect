# Variables d'environnement pour les Supabase Edge Functions
# Copier en .env (ne pas committer .env)

# Supabase (automatiquement injectées en production, à définir pour le dev local)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# OpenAI
OPENAI_API_KEY=sk-...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@modect.app

# Agent Node.js service (apps/agent/)
AGENT_SERVICE_URL=http://localhost:3001
